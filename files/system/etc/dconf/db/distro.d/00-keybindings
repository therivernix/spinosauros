[org/gnome/shell]
always-show-log-out=true

[org/gnome/mutter]
dynamic-workspaces=false

[org/gnome/desktop/wm/preferences]
num-workspaces=4

[org/gnome/desktop/interface]
enable-hot-corners=false

[org/gnome/shell/keybindings]
toggle-quick-settings=['<Super>q']
focus-active-notification=['<Shift><Super>n']
toggle-message-tray=['<Super>n']

[org/gnome/settings-daemon/plugins/media-keys]
media-static=['gnome-control-center']
control-center=['AudioMedia']

[org/gnome/desktop/wm/keybindings]
close=['<Super>w']

move-to-monitor-down=['<Super><Shift>Down']
move-to-monitor-left=['<Super><Shift>Left']
move-to-monitor-right=['<Super><Shift>Right']
move-to-monitor-up=['<Super><Shift>Up']

move-to-workspace-1=['<Shift><Control><Super>1']
move-to-workspace-2=['<Shift><Control><Super>2']
move-to-workspace-3=['<Shift><Control><Super>3']
move-to-workspace-4=['<Shift><Control><Super>4']

move-to-workspace-down=['<Control><Shift><Alt>Down']
move-to-workspace-up=['<Control><Shift><Alt>Up']
move-to-workspace-last=['<Shift><Control><Super>0']
move-to-workspace-left=['<Super><Shift>Page_Up', '<Super><Shift>KP_Prior', '<Super><Shift><Alt>Left', '<Control><Shift><Alt>Left']
move-to-workspace-right=['<Super><Shift>Page_Down', '<Super><Shift>KP_Next', '<Super><Shift><Alt>Right', '<Control><Shift><Alt>Right']

switch-to-workspace-1=['<Control>1']
switch-to-workspace-2=['<Control>2']
switch-to-workspace-3=['<Control>3']
switch-to-workspace-4=['<Control>4']

switch-to-workspace-down=['<Control><Alt>Down']
switch-to-workspace-up=['<Control><Alt>Up']
switch-to-workspace-left=['<Control><Super>Left']
switch-to-workspace-right=['<Control><Super>Right']
switch-to-workspace-last=['<Control><Super>0']

toggle-fullscreen=['<Super>f']

[alphabetical-app-grid]
folder-order-position='end'

[appindicator]
compact-mode-enabled=false
custom-icons=@a(sss) []
icon-brightness=0.0
icon-contrast=0.0
icon-opacity=240
icon-saturation=0.0
icon-size=0
legacy-tray-enabled=false
tray-pos='right'

[blur-my-shell]
rounded-blur-found=false
settings-version=2

[blur-my-shell/appfolder]
brightness=0.59999999999999998
sigma=30

[blur-my-shell/applications]
pipeline='pipeline_default'

[blur-my-shell/coverflow-alt-tab]
pipeline='pipeline_default'

[blur-my-shell/dash-to-dock]
blur=false
brightness=0.59999999999999998
override-background=true
pipeline='pipeline_default_rounded'
sigma=30
static-blur=true
style-dash-to-dock=0

[blur-my-shell/lockscreen]
pipeline='pipeline_default'

[blur-my-shell/overview]
pipeline='pipeline_default'

[blur-my-shell/panel]
blur=true
brightness=0.59999999999999998
corner-radius=0
force-light-text=true
pipeline='pipeline_default'
sigma=30
static-blur=false

[blur-my-shell/screenshot]
pipeline='pipeline_default'

[blur-my-shell/window-list]
brightness=0.59999999999999998
sigma=30

[caffeine]
cli-toggle=false
indicator-position-max=2
user-enabled=true

[clipboard-indicator]
blink-icon-on-copy=true
clear-history-interval=1440
clear-history-on-interval=true
clear-on-boot=true
disable-down-arrow=true
display-mode=0
excluded-apps=['1password']
next-history-clear=1781441100
open-at-cursor=true
paste-on-select=true
strip-text=true
toggle-menu=['<Super>v']

[dash-to-dock]
always-center-icons=false
apply-custom-theme=false
autohide=true
background-color='rgb(0,0,0)'
background-opacity=0.80000000000000004
click-action='previews'
custom-background-color=false
custom-theme-shrink=true
dash-max-icon-size=48
dock-fixed=true
dock-position='LEFT'
extend-height=true
height-fraction=0.90000000000000002
hot-keys=false
intellihide=true
intellihide-mode='FOCUS_APPLICATION_WINDOWS'
preferred-monitor=-2
preferred-monitor-by-connector='eDP-1'
pressure-threshold=50.0
running-indicator-style='DEFAULT'
show-apps-always-in-the-edge=true

[hotedge]
fallback-in-use=false
show-animation=false

[just-perfection]
activities-button=true
dash-app-running=false
events-button=false
support-notifier-showed-version=36

[libpanel]
alignment='right'
layout=[['gnome@main', 'quick-settings-audio-panel@rayzeq.github.io/main']]
single-column=false

[nightthemeswitcher/time]
location=(50.900727669070911, 5.4187500000000002)
manual-schedule=true
nightthemeswitcher-ondemand-keybinding=['<Shift><Super>t']
sunrise=7.0
sunset=20.0

[restartto]
blacklist=['Fedora', 'EFI USB Device', 'EFI Network', 'EFI DVD/CDROM']

[tiling-assistant]
focus-hint-color='rgb(53,132,228)'
last-version-installed=54
overridden-settings={'org.gnome.mutter.edge-tiling': <@mb nothing>, 'org.gnome.desktop.wm.keybindings.maximize': <@mb nothing>, 'org.gnome.desktop.wm.keybindings.unmaximize': <@mb nothing>, 'org.gnome.mutter.keybindings.toggle-tiled-left': <@mb nothing>, 'org.gnome.mutter.keybindings.toggle-tiled-right': <@mb nothing>}
